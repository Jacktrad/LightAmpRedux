<UserControl x:Class="BardMusicPlayer.Ui.Classic.Classic_MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:control="clr-namespace:BardMusicPlayer.Ui.Controls"
             xmlns:Locale="clr-namespace:BardMusicPlayer.Ui.Locales"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1280"
             Width="Auto"
             Height="Auto"
             MinWidth="520"
             MinHeight="430"
             Loaded="Window_Loaded"
             PreviewKeyDown="ClassicMainView_PreviewKeyDown"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/ImageButtonStyle.xaml"/>
                <ResourceDictionary Source="../Themes/DefaultTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SongMetadataToggleStyle"
                   TargetType="ToggleButton">
                <Setter Property="Height" Value="27"/>
                <Setter Property="MinWidth" Value="34"/>
                <Setter Property="Margin" Value="3,1"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="Foreground"
                        Value="{DynamicResource TextMainBrush}"/>
                <Setter Property="Background"
                        Value="{DynamicResource ControlElementBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{DynamicResource GlassBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="MetadataBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MetadataBorder"
                                            Property="BorderBrush"
                                            Value="{DynamicResource AccentOrangeBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="MetadataBorder"
                                            Property="Background"
                                            Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                                    <Setter TargetName="MetadataBorder"
                                            Property="BorderBrush"
                                            Value="{DynamicResource AccentOrangeBorderHover}"/>
                                    <Setter TargetName="MetadataBorder"
                                            Property="Effect"
                                            Value="{DynamicResource NeonSoftGlowEffect}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AssignedSongTagChipStyle"
                   TargetType="Button">
                <Setter Property="Height" Value="25"/>
                <Setter Property="MinWidth" Value="42"/>
                <Setter Property="Margin" Value="3,1"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="Foreground"
                        Value="{DynamicResource TextMainBrush}"/>
                <Setter Property="Background"
                        Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{DynamicResource AccentOrangeBorderHover}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="ToolTip"
                        Value="Click to remove this tag"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="TagChipBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="  ×"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TagChipBorder"
                                            Property="Effect"
                                            Value="{DynamicResource NeonSoftGlowEffect}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="TagChipBorder"
                                            Property="Opacity"
                                            Value="0.72"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


            <Style x:Key="DashboardResizeVerticalThumbStyle"
                   TargetType="Thumb">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Background"
                        Value="{DynamicResource AccentOrangeBrush}"/>
                <Setter Property="Opacity" Value="0.14"/>
                <Setter Property="Panel.ZIndex" Value="80"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.92"/>
                        <Setter Property="Effect"
                                Value="{DynamicResource NeonSoftGlowEffect}"/>
                    </Trigger>
                    <Trigger Property="IsDragging" Value="True">
                        <Setter Property="Opacity" Value="1"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DashboardResizeHorizontalThumbStyle"
                   TargetType="Thumb">
                <Setter Property="Height" Value="8"/>
                <Setter Property="Background"
                        Value="{DynamicResource AccentOrangeBrush}"/>
                <Setter Property="Opacity" Value="0.14"/>
                <Setter Property="Panel.ZIndex" Value="80"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.92"/>
                        <Setter Property="Effect"
                                Value="{DynamicResource NeonSoftGlowEffect}"/>
                    </Trigger>
                    <Trigger Property="IsDragging" Value="True">
                        <Setter Property="Opacity" Value="1"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DashboardResizeCornerThumbStyle"
                   TargetType="Thumb">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Background"
                        Value="{DynamicResource AccentOrangeBrush}"/>
                <Setter Property="Opacity" Value="0.22"/>
                <Setter Property="Panel.ZIndex" Value="90"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="7"
                                    BorderBrush="{DynamicResource TextMainBrush}"
                                    BorderThickness="1"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Effect"
                                Value="{DynamicResource NeonGlowEffect}"/>
                    </Trigger>
                    <Trigger Property="IsDragging" Value="True">
                        <Setter Property="Opacity" Value="1"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        This layout preserves the original control names and click/change handlers.
        The Mockup* styles come from BlackGlassNeonTheme_MockupReady.xaml.
        DynamicResource is used so the view still loads before an external theme is selected.
    -->
    <Border Margin="8"
            Style="{DynamicResource MockupAppShellStyle}">

        <Grid x:Name="ResponsiveLayoutRoot"
              ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn"
                                  Width="290"/>
                <ColumnDefinition x:Name="LeftSidebarHandleColumn"
                                  Width="10"/>
                <ColumnDefinition x:Name="MainDashboardColumn"
                                  Width="*"/>
                <ColumnDefinition x:Name="RightSidebarHandleColumn"
                                  Width="0"/>
                <ColumnDefinition x:Name="RightSidebarColumn"
                                  Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- =========================================================
                 INDEPENDENT PLAYLIST / HISTORY DOCK PANELS
                 ========================================================= -->

            <ScrollViewer x:Name="LeftDockScroller"
                          Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          Background="Transparent">
                <StackPanel x:Name="LeftDockHost"
                            HorizontalAlignment="Stretch">

                    <!-- Initially placed on the left. Code-behind moves either
                         panel to LeftDockHost or RightDockHost independently. -->
                    <Border x:Name="PlaylistDockPanel"
                            Tag="Playlist"
                            Width="290"
                            Height="410"
                            MinWidth="190"
                            MaxWidth="620"
                            MinHeight="220"
                            MaxHeight="1100"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            ClipToBounds="True"
                            Style="{DynamicResource MockupSidebarPanelStyle}">

                        <Grid>
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="2,0,2,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Border Width="34"
                                                Height="34"
                                                Margin="0,0,10,0"
                                                CornerRadius="9"
                                                Background="{DynamicResource AccentOrangeSelectedBrush}"
                                                BorderBrush="{DynamicResource AccentOrangeBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="♫"
                                                       FontSize="20"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="PLAYLISTS"
                                                       Style="{DynamicResource MockupSectionHeaderStyle}"
                                                       Margin="0"/>
                                            <TextBlock Text="Your performance sets"
                                                       Style="{DynamicResource MockupSubtitleStyle}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">

                                        <Button x:Name="PlaylistDockButton"
                                                Width="42"
                                                Height="25"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                Click="PlaylistDockButton_Click"
                                                ToolTip="Move Playlist to the other side"/>

                                        <Button x:Name="PlaylistResetSizeButton"
                                                Content="↺"
                                                Width="28"
                                                Height="25"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                Click="PlaylistResetSizeButton_Click"
                                                ToolTip="Reset Playlist size"/>

                                        <Button x:Name="PlaylistHideButton"
                                                Content="×"
                                                Width="28"
                                                Height="25"
                                                Padding="0"
                                                Click="PlaylistHideButton_Click"
                                                ToolTip="Hide Playlist"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        Style="{DynamicResource MockupNeonSeparatorStyle}"/>

                                <Grid Grid.Row="2"
                                      x:Name="PlaylistGrid"
                                      Background="Transparent"
                                      Margin="0,4,0,8"
                                      Visibility="Visible">
                                    <control:Playlist x:Name="PlaylistCtl"
                                                      Background="Transparent"/>
                                </Grid>

                                <Border Grid.Row="3"
                                        Style="{DynamicResource MockupCompactCardStyle}"
                                        Margin="0,4,0,0">
                                    <StackPanel>
                                        <TextBlock Text="CURRENT INSTRUMENT"
                                                   Style="{DynamicResource MockupAccentLabelStyle}"
                                                   Margin="0,0,0,3"/>
                                        <Label x:Name="InstrumentInfo"
                                               Content="None"
                                               Padding="0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMainBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Only the resize grips appropriate to the current
                                 dock side are made visible by code-behind. -->
                            <Thumb x:Name="PlaylistLeftResizeThumb"
                                   Tag="Playlist:Left"
                                   Style="{StaticResource DashboardResizeVerticalThumbStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Stretch"
                                   Cursor="SizeWE"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="PlaylistRightResizeThumb"
                                   Tag="Playlist:Right"
                                   Style="{StaticResource DashboardResizeVerticalThumbStyle}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Stretch"
                                   Cursor="SizeWE"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="PlaylistBottomResizeThumb"
                                   Tag="Playlist:Bottom"
                                   Style="{StaticResource DashboardResizeHorizontalThumbStyle}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Bottom"
                                   Cursor="SizeNS"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="PlaylistBottomLeftResizeThumb"
                                   Tag="Playlist:BottomLeft"
                                   Style="{StaticResource DashboardResizeCornerThumbStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom"
                                   Cursor="SizeNESW"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="PlaylistBottomRightResizeThumb"
                                   Tag="Playlist:BottomRight"
                                   Style="{StaticResource DashboardResizeCornerThumbStyle}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Cursor="SizeNWSE"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>
                        </Grid>
                    </Border>

                    <Border x:Name="HistoryDockPanel"
                            Tag="History"
                            Width="290"
                            Height="250"
                            MinWidth="190"
                            MaxWidth="620"
                            MinHeight="150"
                            MaxHeight="1100"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            ClipToBounds="True"
                            Style="{DynamicResource MockupSidebarPanelStyle}">

                        <Grid>
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="2,0,2,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Border Width="34"
                                                Height="34"
                                                Margin="0,0,10,0"
                                                CornerRadius="9"
                                                Background="{DynamicResource AccentOrangeSelectedBrush}"
                                                BorderBrush="{DynamicResource AccentOrangeBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="↶"
                                                       FontSize="20"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="HISTORY"
                                                       Style="{DynamicResource MockupSectionHeaderStyle}"
                                                       Margin="0"/>
                                            <TextBlock Text="Recently played songs"
                                                       Style="{DynamicResource MockupSubtitleStyle}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">

                                        <Button x:Name="HistoryDockButton"
                                                Width="42"
                                                Height="25"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                Click="HistoryDockButton_Click"
                                                ToolTip="Move History to the other side"/>

                                        <Button x:Name="HistoryResetSizeButton"
                                                Content="↺"
                                                Width="28"
                                                Height="25"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                Click="HistoryResetSizeButton_Click"
                                                ToolTip="Reset History size"/>

                                        <Button x:Name="HistoryHideButton"
                                                Content="×"
                                                Width="28"
                                                Height="25"
                                                Padding="0"
                                                Click="HistoryHideButton_Click"
                                                ToolTip="Hide History"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        Style="{DynamicResource MockupNeonSeparatorStyle}"/>

                                <Border Grid.Row="2"
                                        Margin="0,4,0,0"
                                        Style="{DynamicResource MockupCompactCardStyle}"
                                        Padding="4"
                                        ClipToBounds="True">
                                    <Grid x:Name="HistoryGrid"
                                          Background="Transparent"
                                          Visibility="Visible">
                                        <control:PlayedHistory x:Name="PlayedHistoryCtl"
                                                               Background="{DynamicResource PanelBackgroundBrush}"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Thumb x:Name="HistoryLeftResizeThumb"
                                   Tag="History:Left"
                                   Style="{StaticResource DashboardResizeVerticalThumbStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Stretch"
                                   Cursor="SizeWE"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="HistoryRightResizeThumb"
                                   Tag="History:Right"
                                   Style="{StaticResource DashboardResizeVerticalThumbStyle}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Stretch"
                                   Cursor="SizeWE"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="HistoryBottomResizeThumb"
                                   Tag="History:Bottom"
                                   Style="{StaticResource DashboardResizeHorizontalThumbStyle}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Bottom"
                                   Cursor="SizeNS"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="HistoryBottomLeftResizeThumb"
                                   Tag="History:BottomLeft"
                                   Style="{StaticResource DashboardResizeCornerThumbStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom"
                                   Cursor="SizeNESW"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>

                            <Thumb x:Name="HistoryBottomRightResizeThumb"
                                   Tag="History:BottomRight"
                                   Style="{StaticResource DashboardResizeCornerThumbStyle}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Cursor="SizeNWSE"
                                   DragStarted="SidePanelResizeThumb_DragStarted"
                                   DragDelta="SidePanelResizeThumb_DragDelta"
                                   DragCompleted="SidePanelResizeThumb_DragCompleted"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="RightDockScroller"
                          Grid.Column="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          Background="Transparent">
                <StackPanel x:Name="RightDockHost"
                            HorizontalAlignment="Stretch"/>
            </ScrollViewer>

            <!-- Independent restore icons remain available when a panel is hidden. -->
            <Button x:Name="PlaylistShowButton"
                    Grid.Column="1"
                    Content="P"
                    Width="28"
                    Height="31"
                    Margin="1,78,1,0"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Panel.ZIndex="220"
                    Visibility="Collapsed"
                    Click="PlaylistShowButton_Click"
                    ToolTip="Show Playlist"/>

            <Button x:Name="HistoryShowButton"
                    Grid.Column="1"
                    Content="H"
                    Width="28"
                    Height="31"
                    Margin="1,114,1,0"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Panel.ZIndex="220"
                    Visibility="Collapsed"
                    Click="HistoryShowButton_Click"
                    ToolTip="Show History"/>

            <!-- =========================================================
                 MAIN AREA
                 ========================================================= -->
            <Grid Grid.Column="2"
                  x:Name="MainDashboardArea"
                  MinWidth="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        x:Name="DashboardToolbar"
                        Padding="8,6"
                        Margin="0,0,0,7"
                        CornerRadius="7"
                        Background="{DynamicResource ControlElementBrush}"
                        BorderBrush="{DynamicResource AccentOrangeBrush}"
                        BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <ToggleButton x:Name="DashboardLockButton"
                                          Content="Layout unlocked"
                                          MinWidth="118"
                                          Height="27"
                                          Margin="4,0,0,0"
                                          Checked="DashboardLockButton_Changed"
                                          Unchecked="DashboardLockButton_Changed"
                                          ToolTip="Layout unlocked — Ctrl+Shift+L to lock"/>

                            <Button x:Name="DashboardResetButton"
                                    Content="Reset order"
                                    MinWidth="92"
                                    Height="27"
                                    Margin="5,0,0,0"
                                    Click="DashboardResetButton_Click"/>

                            <Button x:Name="DashboardResetSizesButton"
                                    Content="Reset sizes"
                                    MinWidth="92"
                                    Height="27"
                                    Margin="5,0,0,0"
                                    Click="DashboardResetSizesButton_Click"/>

                            <Button x:Name="DashboardHideToolbarButton"
                                    Content="Hide dashboard"
                                    MinWidth="108"
                                    Height="27"
                                    Margin="5,0,0,0"
                                    Click="DashboardHideToolbarButton_Click"
                                    ToolTip="Hide this dashboard toolbar"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="DASHBOARD"
                                       Style="{DynamicResource MockupAccentLabelStyle}"
                                       VerticalAlignment="Center"/>

                            <TextBlock x:Name="DashboardInstructionText"
                                       Text="  Drag the ☰ in the top-left to move · drag cyan edges/corners to resize"
                                       Style="{DynamicResource MockupSubtitleStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.RowSpan="2"
                        x:Name="LayoutHotkeyToast"
                        MinWidth="138"
                        Height="34"
                        Margin="0,10,0,0"
                        Padding="12,5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Panel.ZIndex="400"
                        Visibility="Collapsed"
                        CornerRadius="8"
                        Background="{DynamicResource ControlElementBrush}"
                        BorderBrush="{DynamicResource AccentOrangeBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="LayoutHotkeyToastText"
                               Text="Layout unlocked"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Grid.RowSpan="2"
                        x:Name="DashboardShowToolbarButton"
                        Content="▦"
                        Width="29"
                        Height="29"
                        Margin="0,4,4,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Panel.ZIndex="250"
                        Visibility="Collapsed"
                        Click="DashboardShowToolbarButton_Click"
                        ToolTip="Show dashboard controls"/>

                <ScrollViewer Grid.Row="1"
                              x:Name="LowerContentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              Padding="0"
                              Background="Transparent">

                    <StackPanel x:Name="DashboardSlotPanel">

                        <ContentControl x:Name="DashboardSlot1"
                                        Tag="1"
                                        Margin="0,0,0,8"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Top"
                                        AllowDrop="True"
                                        DragOver="DashboardSlot_DragOver"
                                        DragLeave="DashboardSlot_DragLeave"
                                        Drop="DashboardSlot_Drop">
                                                    <Grid x:Name="TabsDashboardSection"
                              Tag="Tabs"
                              MinWidth="520"
                              MinHeight="240"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top">

                            <Grid Margin="7">
                                <Grid>
                                    <Border
                        Style="{DynamicResource MockupGlassCardStyle}"
                        Padding="8">

                    <TabControl Background="Transparent"
                                BorderThickness="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ItemContainerStyle="{DynamicResource MockupTopNavigationTabStyle}">

                        <!-- CHAT -->
                        <TabItem Header="Chat">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="34"/>
                                </Grid.RowDefinitions>

                                <RichTextBox x:Name="ChatBox"
                                             Grid.Row="0"
                                             IsReadOnly="False"
                                             Cursor="Arrow"
                                             Padding="8"
                                             Background="{DynamicResource ChatBoxBackground}"
                                             BorderBrush="{DynamicResource GlassBorderBrush}"
