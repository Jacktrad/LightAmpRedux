    <!-- Search/path TextBoxes -->
    <Style x:Key="MockupSearchBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="MinWidth" Value="160"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- Compact selectors -->
    <Style x:Key="MockupCompactComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="118"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Sidebar playlist item -->
    <Style x:Key="MockupSidebarListItemStyle"
           TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="SidebarItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource UiSmallCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SidebarItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource MockupCardHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SidebarItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource MockupSelectedBrush}"/>
                            <Setter TargetName="SidebarItemBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource AccentOrangeBrush}"/>
                            <Setter TargetName="SidebarItemBorder"
                                    Property="Effect"
                                    Value="{DynamicResource NeonSoftGlowEffect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Browser/song row -->
    <Style x:Key="MockupSongListItemStyle"
           TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="SongRowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource UiSmallCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SongRowBorder"
                                    Property="Background"
                                    Value="{DynamicResource MockupCardHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SongRowBorder"
                                    Property="Background"
                                    Value="{DynamicResource MockupSelectedBrush}"/>
                            <Setter TargetName="SongRowBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource AccentOrangeBrush}"/>
                            <Setter TargetName="SongRowBorder"
                                    Property="Effect"
                                    Value="{DynamicResource NeonSoftGlowEffect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Song library DataGrid preset -->
    <Style x:Key="MockupSongDataGridStyle"
           TargetType="DataGrid"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowHeight" Value="34"/>
        <Setter Property="ColumnHeaderHeight" Value="34"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
    </Style>

    <!-- Metadata/status chip -->
    <Style x:Key="MockupStatusBadgeStyle"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MockupOutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="4,0"/>
    </Style>

    <Style x:Key="MockupPlayingBadgeStyle"
           TargetType="Border"
           BasedOn="{StaticResource MockupStatusBadgeStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource MockupSuccessBrush}"/>
        <Setter Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
    </Style>

    <!-- Thin cyan-to-violet separator -->
    <Style x:Key="MockupNeonSeparatorStyle"
           TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource MockupDividerBrush}"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- Playback slider preset, reusing the theme's existing Slider template -->
    <Style x:Key="MockupPlaybackSliderStyle"
           TargetType="Slider"
           BasedOn="{StaticResource {x:Type Slider}}">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Margin" Value="10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Compact keyboard / visualizer frame -->
    <Style x:Key="MockupVisualizerFrameStyle"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource DarkGridBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeSelectedBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
    </Style>

</ResourceDictionary>