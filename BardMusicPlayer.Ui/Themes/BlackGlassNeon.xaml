<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Glass neon dark theme: black glass panels, rounded controls, cyan-violet glow, dark scrollbar -->
    <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0B1020" Offset="0.00"/>
        <GradientStop Color="#FF101827" Offset="0.45"/>
        <GradientStop Color="#FF05070D" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DarkGridBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E016161A" Offset="0.00"/>
        <GradientStop Color="#D00A0A0D" Offset="0.50"/>
        <GradientStop Color="#E0000000" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="#D9141418" Offset="0.00"/>
        <GradientStop Color="#C80B0B0E" Offset="0.55"/>
        <GradientStop Color="#D9000000" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ControlElementBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#D028282D" Offset="0.00"/>
        <GradientStop Color="#C0151519" Offset="0.55"/>
        <GradientStop Color="#D0060608" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ButtonBorderBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7F2D3D" Offset="0.00"/>
        <GradientStop Color="#8A4A22" Offset="0.16"/>
        <GradientStop Color="#82751C" Offset="0.32"/>
        <GradientStop Color="#247A4B" Offset="0.48"/>
        <GradientStop Color="#207687" Offset="0.64"/>
        <GradientStop Color="#275A9B" Offset="0.80"/>
        <GradientStop Color="#763392" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MenuBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E018181C" Offset="0.00"/>
        <GradientStop Color="#D00B0B0E" Offset="0.55"/>
        <GradientStop Color="#E0000000" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ChatBoxBackground" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="#D9141418" Offset="0.00"/>
        <GradientStop Color="#C80A0A0D" Offset="0.55"/>
        <GradientStop Color="#D9000000" Offset="1.00"/>
    </LinearGradientBrush>

    <!-- Rainbow accent brushes - safe XAML-only version -->
    <LinearGradientBrush x:Key="AccentOrangeBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF00F5FF" Offset="0.00"/>
        <GradientStop Color="#FF00B7FF" Offset="0.55"/>
        <GradientStop Color="#FF7A5CFF" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentOrangeHoverBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF55FBFF" Offset="0.00"/>
        <GradientStop Color="#FF19CFFF" Offset="0.55"/>
        <GradientStop Color="#FF9C86FF" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentOrangeSelectedBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF00A8C8" Offset="0.00"/>
        <GradientStop Color="#FF006EA8" Offset="0.55"/>
        <GradientStop Color="#FF4937A8" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentOrangeBorderHover" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF9EFFFF" Offset="0.00"/>
        <GradientStop Color="#FF59DFFF" Offset="0.55"/>
        <GradientStop Color="#FFC6B8FF" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentCyanBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00F5FF" Offset="0.00"/>
        <GradientStop Color="#3B82F6" Offset="0.50"/>
        <GradientStop Color="#A855F7" Offset="1.00"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentCyanFillBrush"        Color="#3300D4FF"/>
    <SolidColorBrush x:Key="AccentRedBrush"             Color="#EF4444"/>

    <!-- User-adjustable resources overridden by UiCustomizationManager. -->
    <CornerRadius x:Key="UiCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="UiSmallCornerRadius">7</CornerRadius>
    <CornerRadius x:Key="UiLargeCornerRadius">13</CornerRadius>
    <CornerRadius x:Key="UiPillCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="UiTopCornerRadius">8,8,0,0</CornerRadius>
    <sys:Boolean x:Key="UiAnimationsEnabled">True</sys:Boolean>
    <Duration x:Key="UiAnimationDuration">0:0:0.2</Duration>

    <!-- Glass, glow, and scrollbar resources -->
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#55FFFFFF"/>
    <SolidColorBrush x:Key="GlassInnerHighlightBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="RainbowScrollTrackBrush" Color="#B008080A"/>

    <DropShadowEffect x:Key="GlassPanelShadowEffect"
                      Color="#000000"
                      BlurRadius="18"
                      ShadowDepth="3"
                      Opacity="0.38"/>

    <DropShadowEffect x:Key="NeonSoftGlowEffect"
                      Color="#00F5FF"
                      BlurRadius="12"
                      ShadowDepth="0"
                      Opacity="0.72"/>

    <DropShadowEffect x:Key="NeonGlowEffect"
                      Color="#00F5FF"
                      BlurRadius="20"
                      ShadowDepth="0"
                      Opacity="0.95"/>

    <SolidColorBrush x:Key="TextMainBrush"              Color="#FFFFFF"/> <SolidColorBrush x:Key="TextMutedBrush"             Color="#94A3B8"/> <SolidColorBrush x:Key="TextDarkBrush"              Color="#0F172A"/> <SolidColorBrush x:Key="TextDarkerBrush"            Color="#64748B"/>

     <Style TargetType="UserControl">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
    </Style>
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource ButtonBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource UiSmallCornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="Border" Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="Border" Property="Effect" Value="{DynamicResource NeonGlowEffect}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource DarkGridBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{DynamicResource AccentOrangeBrush}"/>
        <Setter Property="Padding" Value="7,4"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource UiSmallCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeBrush}"/>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
                <Setter Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background"           Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground"           Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush"          Value="{DynamicResource AccentOrangeBrush}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Padding"              Value="4,2"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground"  Value="{DynamicResource TextMainBrush}"/>
                    <Setter Property="Padding"     Value="6,3"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentOrangeHoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                            <Setter Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource UiSmallCornerRadius}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <ToggleButton Grid.Column="0" Grid.ColumnSpan="2" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{DynamicResource AccentOrangeBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide" Placement="Bottom">
                            <Border Background="{DynamicResource ControlElementBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource UiSmallCornerRadius}"
                                    Effect="{StaticResource GlassPanelShadowEffect}"
                                    MaxHeight="200"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource GlassPanelShadowEffect}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource GlassInnerHighlightBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource UiTopCornerRadius}"
                            Margin="2,0,2,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" TextElement.Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="Border" Property="Effect" Value="{DynamicResource NeonGlowEffect}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="Border" Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElementBrush}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border Name="Box"
                            Width="16" Height="16"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <Path Name="Check"
                              Data="M 2,7 L 6,11 L 13,3"
                              Stroke="{DynamicResource AccentOrangeBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box"    Property="Background"       Value="{DynamicResource PanelBackgroundBrush}"/>
                            <Setter TargetName="Box"    Property="BorderBrush"      Value="{DynamicResource AccentOrangeBrush}"/>
                            <Setter                     Property="Foreground"       Value="{DynamicResource AccentOrangeBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check"  Property="Visibility"       Value="Visible"/>
                            <Setter TargetName="Box"    Property="Background"       Value="{DynamicResource ControlElementBrush}"/>
                            <Setter TargetName="Box"    Property="BorderBrush"      Value="{DynamicResource AccentOrangeBrush}"/>
                            <Setter TargetName="Box"    Property="Effect"           Value="{DynamicResource NeonSoftGlowEffect}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition              Property="IsChecked"        Value="True"/>
                                <Condition              Property="IsMouseOver"      Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box"    Property="Background"       Value="{DynamicResource PanelBackgroundBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter                     Property="Foreground"       Value="{DynamicResource TextMutedBrush}"/>
                            <Setter TargetName="Box"    Property="Opacity"          Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern rainbow scrollbar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource RainbowScrollTrackBrush}"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Margin="2,0"/>
                        <Track x:Name="PART_Track" Orientation="Vertical" IsDirectionReversed="True" Margin="2">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb MinHeight="28">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBorder" Background="{DynamicResource AccentOrangeBrush}" BorderBrush="{DynamicResource AccentOrangeBorderHover}" BorderThickness="1" CornerRadius="5" Margin="1" Opacity="0.88"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentOrangeHoverBrush}"/>
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="ThumbBorder" Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="ThumbBorder" Property="Effect" Value="{DynamicResource NeonGlowEffect}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="12"/>
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent" SnapsToDevicePixels="True">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Margin="0,2"/>
                                <Track x:Name="PART_Track" Orientation="Horizontal" IsDirectionReversed="False" Margin="2">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb MinWidth="28">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="ThumbBorder" Background="{DynamicResource AccentOrangeBrush}" BorderBrush="{DynamicResource AccentOrangeBorderHover}" BorderThickness="1" CornerRadius="5" Margin="1" Opacity="0.88"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentOrangeHoverBrush}"/>
                                                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="ThumbBorder" Property="Effect" Value="{DynamicResource NeonSoftGlowEffect}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                                                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="ThumbBorder" Property="Effect" Value="{DynamicResource NeonGlowEffect}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                            CanContentScroll="{TemplateBinding CanContentScroll}"/>
                        <ScrollBar Grid.Column="1" Grid.Row="0"
                               Name="PART_VerticalScrollBar"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar Grid.Column="0" Grid.Row="1"
                               Name="PART_HorizontalScrollBar"
                               Orientation="Horizontal"
                               Value="{TemplateBinding HorizontalOffset}"
                               Maximum="{TemplateBinding ScrollableWidth}"
                               ViewportSize="{TemplateBinding ViewportWidth}"
                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        <Border Grid.Column="1" Grid.Row="1"
                               Background="{DynamicResource ControlElementBrush}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListView">
        <Setter Property="Background"      Value="{DynamicResource DarkGridBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing"        Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode"    Value="Recycling"/>
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListView">
                    <Border Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource UiCornerRadius}"
                        ClipToBounds="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush"
                                Value="{DynamicResource AccentOrangeBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush"
                                Value="{DynamicResource AccentOrangeBorderHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                    <Setter Property="Padding"    Value="7,4"/>
                    <Setter Property="Margin"     Value="2,1"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource UiSmallCornerRadius}"
                                    Margin="{TemplateBinding Margin}"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource AccentOrangeHoverBrush}"/>
                                        <Setter Property="Foreground"
                                            Value="{DynamicResource TextDarkBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                                        <Setter TargetName="Border" Property="BorderBrush"
                                            Value="{DynamicResource AccentOrangeBorderHover}"/>
                                        <Setter TargetName="Border" Property="Effect"
                                            Value="{DynamicResource NeonGlowEffect}"/>
                                        <Setter Property="Foreground"
                                            Value="{DynamicResource TextMainBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>



    <Style TargetType="GroupBox">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.RowSpan="2" Margin="0,9,0,0" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{DynamicResource UiCornerRadius}" Effect="{StaticResource GlassPanelShadowEffect}"/>
                        <Border Grid.Row="0" Margin="12,0,0,0" Padding="8,3" HorizontalAlignment="Left" Background="{DynamicResource ControlElementBrush}" BorderBrush="{DynamicResource AccentOrangeBrush}" BorderThickness="1" CornerRadius="6">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background"           Value="{DynamicResource DarkGridBrush}"/>
        <Setter Property="Foreground"           Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush"          Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="RowBackground"        Value="{DynamicResource DarkGridBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
        <Setter Property="HeadersVisibility"    Value="Column"/>
        <Setter Property="SelectionMode"        Value="Single"/>
        <Setter Property="CanUserResizeRows"    Value="False"/>
        <Setter Property="RowHeaderWidth"       Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGrid">
                    <Border Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource UiCornerRadius}"
                        ClipToBounds="True">
                        <ScrollViewer x:Name="DG_ScrollViewer" Focusable="False">
                            <ScrollViewer.Template>
                                <ControlTemplate TargetType="ScrollViewer">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <DataGridColumnHeadersPresenter Grid.Column="0" Grid.Row="0"
                                                                    x:Name="PART_ColumnHeadersPresenter"/>
                                        <ScrollContentPresenter Grid.Column="0" Grid.Row="1"
                                                            x:Name="PART_ScrollContentPresenter"
                                                            CanContentScroll="{TemplateBinding CanContentScroll}"/>
                                        <ScrollBar Grid.Column="1" Grid.Row="1"
                                               x:Name="PART_VerticalScrollBar"
                                               Value="{TemplateBinding VerticalOffset}"
                                               Maximum="{TemplateBinding ScrollableHeight}"
                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                                        <ScrollBar Grid.Column="0" Grid.Row="2"
                                               x:Name="PART_HorizontalScrollBar"
                                               Orientation="Horizontal"
                                               Value="{TemplateBinding HorizontalOffset}"
                                               Maximum="{TemplateBinding ScrollableWidth}"
                                               ViewportSize="{TemplateBinding ViewportWidth}"
                                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                                        <Border Grid.Column="1" Grid.Row="2"
                                            Background="{DynamicResource ControlElementBrush}"/>
                                    </Grid>
                                </ControlTemplate>
                            </ScrollViewer.Template>
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush"
                                Value="{DynamicResource AccentOrangeBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush"
                                Value="{DynamicResource AccentOrangeBorderHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{DynamicResource ControlElementBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Name="HeaderBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4,4,0,0"
                        Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                            VerticalAlignment="Center"/>
                            <Path Grid.Column="1" Name="SortArrow"
                              Visibility="Collapsed"
                              Width="8" Height="6"
                              Margin="4,0,0,0"
                              Fill="{DynamicResource AccentOrangeBrush}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background"
                                Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter Property="Foreground"
                                Value="{DynamicResource TextDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background"
                                Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="SortArrow" Property="Data" Value="M 0 6 L 4 0 L 8 6 Z"/>
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="SortArrow" Property="Data" Value="M 0 0 L 4 6 L 8 0 Z"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="Margin" Value="2,1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Border Name="RowBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Margin="{TemplateBinding Margin}">
                        <SelectiveScrollingGrid>
                            <DataGridCellsPresenter/>
                        </SelectiveScrollingGrid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBorder" Property="Background"
                                Value="{DynamicResource AccentOrangeHoverBrush}"/>
                            <Setter Property="Foreground"
                                Value="{DynamicResource TextDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBorder" Property="Background"
                                Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                            <Setter TargetName="RowBorder" Property="BorderBrush"
                                Value="{DynamicResource AccentOrangeBorderHover}"/>
                            <Setter TargetName="RowBorder" Property="Effect"
                                Value="{DynamicResource NeonGlowEffect}"/>
                            <Setter Property="Foreground"
                                Value="{DynamicResource TextMainBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"        Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                        BorderThickness="0"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground"       Value="{DynamicResource AccentOrangeBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding"           Value="4,0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Song title used by LightAmp's existing SongName TextBox -->
    <Style x:Key="SongNameStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Margin" Value="3,0,5,0"/>
        <Setter Property="MinHeight" Value="38"/>
    </Style>

    <!-- ============================================================
         MOCKUP-READY UI KIT
         These named styles are intentionally opt-in. They do not
         rearrange LightAmp by themselves; apply them in the view XAML.
         ============================================================ -->

    <!-- Additional shell/card brushes -->
    <LinearGradientBrush x:Key="MockupShellBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#FF05070D" Offset="0"/>
        <GradientStop Color="#FF090E19" Offset="0.52"/>
        <GradientStop Color="#FF030407" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MockupSidebarBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#F0121722" Offset="0"/>
        <GradientStop Color="#F0070A10" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MockupCardBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#D61A202C" Offset="0"/>
        <GradientStop Color="#D10A0E16" Offset="0.58"/>
        <GradientStop Color="#DF05070B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MockupCardHoverBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#D9233042" Offset="0"/>
        <GradientStop Color="#DC0E1725" Offset="0.55"/>
        <GradientStop Color="#E0070A11" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MockupSelectedBrush"
                         StartPoint="0,0"
                         EndPoint="1,0">
        <GradientStop Color="#A5260E58" Offset="0"/>
        <GradientStop Color="#A30A3B65" Offset="0.55"/>
        <GradientStop Color="#9A06253D" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MockupDividerBrush"
                         StartPoint="0,0"
                         EndPoint="1,0">
        <GradientStop Color="#0000F5FF" Offset="0"/>
        <GradientStop Color="#A000F5FF" Offset="0.28"/>
        <GradientStop Color="#B07A5CFF" Offset="0.72"/>
        <GradientStop Color="#007A5CFF" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="MockupOutlineBrush" Color="#704D6078"/>
    <SolidColorBrush x:Key="MockupSuccessBrush" Color="#45E59A"/>
    <SolidColorBrush x:Key="MockupWarningBrush" Color="#FFBD59"/>
    <SolidColorBrush x:Key="MockupDangerBrush" Color="#FF5D73"/>
    <SolidColorBrush x:Key="MockupInactiveBrush" Color="#667085"/>

    <DropShadowEffect x:Key="MockupCardShadowEffect"
                      Color="#000000"
                      BlurRadius="24"
                      ShadowDepth="5"
                      Opacity="0.48"/>

    <DropShadowEffect x:Key="MockupPrimaryGlowEffect"
                      Color="#00EFFF"
                      BlurRadius="25"
                      ShadowDepth="0"
                      Opacity="0.82"/>

    <!-- Main application shell -->
    <Style x:Key="MockupAppShellStyle"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MockupShellBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MockupOutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- General floating glass card -->
    <Style x:Key="MockupGlassCardStyle"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MockupCardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Effect" Value="{StaticResource MockupCardShadowEffect}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="MockupCompactCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource MockupGlassCardStyle}">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="9"/>
    </Style>

    <!-- Playlist/sidebar panel -->
    <Style x:Key="MockupSidebarPanelStyle"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MockupSidebarBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MockupOutlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Effect" Value="{StaticResource MockupCardShadowEffect}"/>
    </Style>

    <!-- Now Playing hero card -->
    <Style x:Key="MockupNowPlayingCardStyle"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MockupCardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Effect" Value="{DynamicResource MockupPrimaryGlowEffect}"/>
    </Style>

    <!-- Text hierarchy -->
    <Style x:Key="MockupSectionHeaderStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="MockupHeroTitleStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="MockupSubtitleStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="MockupAccentLabelStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="MockupEmptyStateStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Navigation tabs for the top bar -->
    <Style x:Key="MockupTopNavigationTabStyle"
           TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="NavigationBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource UiTopCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ContentSource="Header"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavigationBorder"
                                    Property="Background"
                                    Value="{DynamicResource MockupCardHoverBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextMainBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="NavigationBorder"
                                    Property="Background"
                                    Value="{DynamicResource MockupSelectedBrush}"/>
                            <Setter TargetName="NavigationBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource AccentOrangeBrush}"/>
                            <Setter TargetName="NavigationBorder"
                                    Property="Effect"
                                    Value="{DynamicResource NeonSoftGlowEffect}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextMainBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- General toolbar button -->
    <Style x:Key="MockupIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
    </Style>

    <!-- Secondary transport button -->
    <Style x:Key="MockupTransportButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="MinWidth" Value="44"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <!-- Main Play button -->
    <Style x:Key="MockupPrimaryPlayButtonStyle"
           TargetType="Button">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{DynamicResource AccentOrangeBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeBorderHover}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Effect" Value="{DynamicResource MockupPrimaryGlowEffect}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PlayButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="30">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PlayButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource AccentOrangeHoverBrush}"/>
                            <Setter TargetName="PlayButtonBorder"
                                    Property="Effect"
                                    Value="{DynamicResource NeonGlowEffect}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PlayButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                            <Setter TargetName="PlayButtonBorder"
                                    Property="RenderTransformOrigin"
                                    Value="0.5,0.5"/>
                            <Setter TargetName="PlayButtonBorder"
                                    Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Rounded pill used for track, instrument and speed selectors -->
