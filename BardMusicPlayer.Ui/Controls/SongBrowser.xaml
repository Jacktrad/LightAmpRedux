<UserControl x:Class="BardMusicPlayer.Ui.Controls.SongBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:Locale ="clr-namespace:BardMusicPlayer.Ui.Locales"
             mc:Ignorable="d" 
             Background="{DynamicResource BackgroundBrush}"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.95*"/>
                <ColumnDefinition Width="26"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="108"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="94"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="Path:"
                   Padding="4,0"
                   Margin="0,0,4,0"
                   VerticalContentAlignment="Center"/>

            <TextBox Grid.Column="1"
                     x:Name="SongPath"
                     Text=""
                     MinWidth="120"
                     Margin="0,0,4,0"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Stretch"
                     TextChanged="SongPath_TextChanged"/>

            <Button Grid.Column="2"
                    Content="..."
                    Width="24"
                    Height="24"
                    Click="Button_Click"
                    ToolTip="{x:Static Locale:Language.SongeBrowser_TargetDir}"/>

            <Label Grid.Column="4"
                   Content="Search:"
                   Padding="4,0"
                   Margin="0,0,4,0"
                   VerticalContentAlignment="Center"/>

            <TextBox Grid.Column="5"
                     x:Name="SongSearch"
                     Text=""
                     MinWidth="100"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Stretch"
                     TextChanged="SongSearch_TextChanged"/>

            <Label Grid.Column="7"
                   Content="Filter by tag:"
                   Padding="4,0"
                   Margin="0,0,4,0"
                   VerticalContentAlignment="Center"/>

            <ToggleButton Grid.Column="8"
                          x:Name="TagFilterDropDownButton"
                          Content="All tags"
                          MinWidth="150"
                          Height="24"
                          Padding="8,2"
                          HorizontalContentAlignment="Left"
                          Foreground="{DynamicResource TextMainBrush}"
                          ToolTip="Check several tags. Songs must contain every checked tag."/>

            <Popup x:Name="TagFilterPopup"
                   PlacementTarget="{Binding ElementName=TagFilterDropDownButton}"
                   Placement="Bottom"
                   IsOpen="{Binding IsChecked, ElementName=TagFilterDropDownButton, Mode=TwoWay}"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   PopupAnimation="Fade"
                   Opened="TagFilterPopup_Opened"
                   Closed="TagFilterPopup_Closed">
                <Border Width="290"
                        MaxHeight="360"
                        Padding="10"
                        CornerRadius="8"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentOrangeBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,8">
                            <TextBlock Text="Filter tags"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="Songs must contain all checked tags"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      MaxHeight="260"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TagFilterItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="2,3"
                                                  Foreground="{DynamicResource TextMainBrush}"
                                                  Click="TagFilterCheckBox_Click"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Grid.Row="2"
                              Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Changes apply when closed"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Content="Clear"
                                    MinWidth="64"
                                    Height="24"
                                    Click="TagFilterClearButton_Click"
                                    ToolTip="Clear all selected tag filters"/>
                        </Grid>
                    </Grid>
                </Border>
            </Popup>

            <Label Grid.Column="10"
                   Content="Rating:"
                   Padding="4,0"
                   Margin="0,0,4,0"
                   VerticalContentAlignment="Center"/>

            <ComboBox Grid.Column="11"
                      x:Name="RatingFilterComboBox"
                      Height="24"
                      MinWidth="104"
                      VerticalContentAlignment="Center"
                      Foreground="{DynamicResource TextMainBrush}"
                      SelectionChanged="RatingFilterComboBox_SelectionChanged"
                      ToolTip="Filter songs by their exact saved rating">
                <ComboBoxItem Content="All ratings"
                              Tag="-1"/>
                <ComboBoxItem Content="Unrated"
                              Tag="0"/>
                <ComboBoxItem Content="★"
                              Tag="1"/>
                <ComboBoxItem Content="★★"
                              Tag="2"/>
                <ComboBoxItem Content="★★★"
                              Tag="3"/>
                <ComboBoxItem Content="★★★★"
                              Tag="4"/>
                <ComboBoxItem Content="★★★★★"
                              Tag="5"/>
            </ComboBox>

            <ToggleButton Grid.Column="13"
                          x:Name="FavoritesOnlyButton"
                          Content="★ Favorites"
                          Height="24"
                          MinWidth="88"
                          Padding="7,2"
                          HorizontalContentAlignment="Center"
                          Click="FavoritesOnlyButton_Click"
                          ToolTip="Show only songs marked as Favorite"/>

            <Button Grid.Column="14"
                    Content="↻"
                    Width="28"
                    Height="24"
                    Click="TagFilterRefreshButton_Click"
                    ToolTip="Refresh tags, ratings, favorites and song results"/>
        </Grid>

                <Grid Grid.Row="1"
              Margin="0,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="98"/>
                <ColumnDefinition Width="92"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="View:"
                   Padding="4,0"
                   HorizontalAlignment="Left"
                   VerticalContentAlignment="Center"/>

            <ToggleButton Grid.Column="1"
                          x:Name="FlatViewButton"
                          Content="Flat"
                          Height="24"
                          Margin="0,0,4,0"
                          Click="FlatViewButton_Click"
                          ToolTip="Use the original recursive flat song list"/>

            <ToggleButton Grid.Column="2"
                          x:Name="TreeViewButton"
                          Content="Tree"
                          Height="24"
                          Margin="0,0,4,0"
                          Click="TreeViewButton_Click"
                          ToolTip="Group Local songs into collapsible folders"/>

            <Button Grid.Column="4"
                    x:Name="ExpandAllFoldersButton"
                    Content="Expand loaded"
                    ToolTip="Expand folders that have already been loaded"
                    Height="24"
                    Margin="0,0,4,0"
                    Visibility="Collapsed"
                    Click="ExpandAllFoldersButton_Click"/>

            <Button Grid.Column="5"
                    x:Name="CollapseAllFoldersButton"
                    Content="Collapse all"
                    ToolTip="Collapse all currently loaded folders"
                    Height="24"
                    Visibility="Collapsed"
                    Click="CollapseAllFoldersButton_Click"/>

            <TextBlock Grid.Column="6"
                       x:Name="TagFilterStatusText"
                       Margin="8,0,4,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <Grid Grid.Row="2">
<ListView x:Name="SongbrowserContainer" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" BorderThickness="0" 
                    ScrollViewer.HorizontalScrollBarVisibility="Visible"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                         ScrollViewer.CanContentScroll="True">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add To Playlist" Click="AddToPlaylist_Click" ToolTip="{x:Static Locale:Language.Global_Load_Song_To_Playlist}"/>
                    <MenuItem Header="Song Preview" Click="LoadSongToPreview" ToolTip="{x:Static Locale:Language.Global_Load_Song_To_Preview}"/>
                    <MenuItem Header="Upload to BMP Midi" Click="UploadToBMP_Click" />
                    <!--<MenuItem Header="Show Information"></MenuItem>-->
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Value}"/>
                </DataTemplate>

            </ListView.ItemTemplate>
        </ListView>

            <TreeView x:Name="SongTreeContainer"
                      Visibility="Collapsed"
                      BorderThickness="0"
                      Background="Transparent"
                      Foreground="{DynamicResource TextMainBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True"
                      PreviewMouseDoubleClick="SongTreeContainer_PreviewMouseDoubleClick"
                      PreviewMouseRightButtonDown="SongTreeContainer_PreviewMouseRightButtonDown"
                      KeyDown="SongTreeContainer_KeyDown">

                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add To Playlist"
                                  Click="AddToPlaylist_Click"
                                  ToolTip="{x:Static Locale:Language.Global_Load_Song_To_Playlist}"/>
                        <MenuItem Header="Song Preview"
                                  Click="LoadSongToPreview"
                                  ToolTip="{x:Static Locale:Language.Global_Load_Song_To_Preview}"/>
                        <MenuItem Header="Upload to BMP Midi"
                                  Click="UploadToBMP_Click"/>
                    </ContextMenu>
                </TreeView.ContextMenu>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}"
                                       Width="24"
                                       Margin="0,0,3,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding FullPath}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded"
                                Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMainBrush}"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Padding"
                                Value="2,1"/>
                        <EventSetter Event="Expanded"
                                     Handler="SongTreeItem_Expanded"/>
                        <EventSetter Event="Collapsed"
                                     Handler="SongTreeItem_Collapsed"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource AccentOrangeSelectedBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextMainBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextMutedBrush}"/>
                                <Setter Property="Opacity"
                                        Value="0.72"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>

        </Grid>

    </Grid>
</UserControl>
